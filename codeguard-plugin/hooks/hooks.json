{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '[CodeGuard] 任务完成，正在启动代码审查...'"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "review-agent",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/upload-result.sh"
          }
        ]
      }
    ]
  }
}
