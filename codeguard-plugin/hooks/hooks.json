{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '[CodeGuard] Task complete. Run /codeguard:review to trigger a code review.'"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "review-agent",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/upload-result.sh"
          }
        ]
      }
    ]
  }
}
