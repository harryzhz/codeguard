# CodeGuard Server Configuration
# Copy this file to .env and edit the values

# Database connection (PostgreSQL for production, SQLite for development)
DATABASE_URL=postgresql+asyncpg://codeguard:codeguard@db:5432/codeguard
# DATABASE_URL=sqlite+aiosqlite:///codeguard.db

# API Key for authentication (set a random secret, shared between server and plugin)
CODEGUARD_API_KEY=CODE_GUARD

# CodeGuard server URL (used by plugin to upload reviews)
CODEGUARD_SERVER=http://localhost:9527

# Storage backend (postgres or sqlite)
STORAGE_BACKEND=postgres

# PostgreSQL credentials (used by docker-compose)
POSTGRES_USER=codeguard
POSTGRES_PASSWORD=codeguard
POSTGRES_DB=codeguard
